---
/**
 * Динамический маршрут статьи (en — язык сайта на корне): /{category}/{slug}/ (§7, §8.1).
 * getStaticPaths берёт только опубликованные en-статьи из коллекции `articles`;
 * URL строится из frontmatter (category + slug). Сайт одноязычный — en.
 */
import type { GetStaticPaths } from 'astro';
import { getCollectionSafe } from '../../loaders/getCollectionSafe';
import ArticlePage from '../../layouts/ArticlePage.astro';
import type { Lang } from '../../i18n';

export const getStaticPaths = (async () => {
  const all = await getCollectionSafe('articles', (entry) => entry.data.draft !== true);
  const en = all.filter((entry) => entry.data.lang === 'en');
  const availableLangs: Lang[] = ['en'];
  return en.map((entry) => ({
    params: { category: entry.data.category, slug: entry.data.slug },
    props: {
      entry,
      siblings: en,
      availableLangs,
    },
  }));
}) satisfies GetStaticPaths;

const { entry, siblings, availableLangs } = Astro.props;
---

<ArticlePage lang="en" entry={entry} siblings={siblings} availableLangs={availableLangs} />
