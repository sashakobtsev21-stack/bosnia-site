---
/**
 * HomePage (§8.4) — главная, направление «Полевой журнал».
 * Один компонент для ru (`/`) и uk (`/uk/`) — язык приходит пропсом, весь
 * текст из словарей (§12). Контента в коллекциях нет (R2) → честные пустые
 * состояния, без выдуманных статей/мест/цен (CLAUDE правило 4).
 *
 * Посыл — справочный и коллективный: места отбираются по высокому рейтингу и
 * сверяются с опытными путешественниками, гидами и местными жителями. Без
 * персональной личности автора.
 *
 * Состав: hero+поиск → витрина (золотая лента) + строка доверия → бэнд
 * «Услуги для жизни в Боснии и Герцеговине» (CTA) → свежие материалы → о проекте → footer (в Base).
 */
import { getCollectionSafe } from '../loaders/getCollectionSafe';
import BaseLayout from './BaseLayout.astro';
import {
  t,
  ALL_SECTION_KEYS,
  sectionHref,
  articleHref,
  formatDate,
  type Lang,
  type SectionKey,
} from '../i18n';
import ShowcaseRail, { type ShowcaseItem } from '../components/ShowcaseRail.astro';
import SearchBox, { type SearchItem } from '../components/SearchBox.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Icon from '../components/Icon.astro';
import EmptyHint from '../components/EmptyHint.astro';
// Hero-фон — кросс-фейд CC-фото (.hero__bg) поверх градиента (.hero — фолбэк под фото).
// 3 реальных CC-фото Боснии и Герцеговины (Мостар/Сараево/Почитель), 1920×860 webp
// ≤200 КБ, атрибуция автор+лицензия из Wikimedia Commons (память фото-уникальность).

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const dict = t(lang);

const pageTitle = `${dict.siteName} — ${dict.tagline}`;
const description = dict.home.heroSubtitle;

// Hero-кадры (§8.4): кросс-фейд по очереди (/js/hero-rotate.js). Первый — LCP
// (eager/high), остальные lazy. Самый узнаваемый кадр (мост в Мостаре) — первым.
const heroImages = [
  {
    src: '/images/hero-stari-most.webp',
    w: 1920,
    h: 860,
    author: 'Ramirez',
    license: 'CC BY-SA 4.0',
    href: 'https://commons.wikimedia.org/wiki/File:Mostar_Old_Town_Panorama_2007.jpg',
  },
  {
    src: '/images/hero-sarajevo.webp',
    w: 1920,
    h: 860,
    author: 'Julian Nyča',
    license: 'CC BY-SA 4.0',
    href: 'https://commons.wikimedia.org/wiki/File:Sarajevo_City_Panorama.JPG',
  },
  {
    src: '/images/hero-pocitelj.webp',
    w: 1920,
    h: 860,
    author: 'Pudelek (Marcin Szala)',
    license: 'CC BY-SA 3.0',
    href: 'https://commons.wikimedia.org/wiki/File:Po%C4%8Ditelj_-_pano.jpg',
  },
];
const heroCredit = (img: (typeof heroImages)[number]): string =>
  img.author ? `${dict.home.photoPrefix}: ${img.author} / Wikimedia Commons, ${img.license}` : '';

/**
 * Индекс для клиентского поиска (§8.4): берём опубликованные статьи этого
 * языка. На R2 коллекция пуста → items = [] → SearchBox показывает корректное
 * пустое состояние. Никаких подделанных результатов.
 */
const articles = await getCollectionSafe(
  'articles',
  (entry) => entry.data.lang === lang && entry.data.draft !== true && entry.data.demo !== true,
);
const routes = await getCollectionSafe(
  'routes',
  (entry) => entry.data.lang === lang && entry.data.draft !== true && entry.data.demo !== true,
);
const visibleCutoff = Date.now();
const visibleArticles = articles.filter((entry) => entry.data.publishedAt.getTime() <= visibleCutoff);
const visibleRoutes = routes.filter((entry) => entry.data.publishedAt.getTime() <= visibleCutoff);

const searchItems: SearchItem[] = visibleArticles.map((entry) => ({
  title: entry.data.title,
  url: articleHref(lang, entry.data.category, entry.data.slug),
  section: dict.nav[entry.data.category as SectionKey] ?? entry.data.category,
}));

/**
 * Свежие материалы (§8.4): 6 самых новых опубликованных материалов этого языка.
 * Новости показываются отдельной лентой выше, будущие даты не всплывают до срока.
 */
const freshCards = [
  ...visibleArticles.filter((entry) => entry.data.category !== 'news'),
  ...visibleRoutes,
]
  .sort((a, b) => {
    const diff = b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
    return diff !== 0 ? diff : a.data.slug.localeCompare(b.data.slug);
  })
  .slice(0, 6)
  .map((entry) => {
    const verifiedAt = 'verifiedAt' in entry.data ? entry.data.verifiedAt : undefined;
    return {
      key: entry.id,
      href: articleHref(lang, entry.data.category, entry.data.slug),
      title: entry.data.title,
      description: entry.data.description,
      cover: entry.data.cover,
      date: formatDate(verifiedAt ?? entry.data.updatedAt, lang),
      verified: (verifiedAt ? 'verified' : 'updated') as 'verified' | 'updated',
      verifiedPhoto: 'verifiedPhoto' in entry.data ? entry.data.verifiedPhoto : undefined,
    };
  });
const hasFresh = freshCards.length > 0;

/**
 * Блок «Новости» на главной (§8.4): всегда последние 3 опубликованные новости.
 * Не фильтруем по возрасту, чтобы блок не пустел между новостными циклами.
 */
const homeNews = visibleArticles
  .filter((entry) => entry.data.category === 'news')
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3)
  .map((entry) => ({
    href: articleHref(lang, 'news', entry.data.slug),
    title: entry.data.title,
    date: formatDate(entry.data.verifiedAt ?? entry.data.publishedAt, lang),
    iso: entry.data.publishedAt.toISOString().slice(0, 10),
  }));
const hasHomeNews = homeNews.length > 0;

/**
 * Витрина (§8.4/§16): золотая лента из ключевых материалов + одно открытое
 * рекламное место (инвентарь под продажу). Подборка курируется по слугам, но
 * обложка/заголовок берутся из коллекции — реальные данные, не выдумываем
 * (CLAUDE правило 4). Маршруты живут в отдельной коллекции `routes`.
 */
const showcaseRestaurants = await getCollectionSafe(
  'restaurants',
  (entry) => entry.data.lang === lang && entry.data.draft !== true,
);
// Заведения перемешаны со статьями/маршрутами (не подряд) — решение владельца.
// Витрина наполняется по мере публикации featured-контента Боснии: города-гайды
// (Сараево/Мостар/Требине) + ключевые статьи (маршруты, аренда авто, day-trips,
// сезон, eSIM) — чтобы лента крутилась непрерывно и без видимых повторов (клоны
// добавляет /js/showcase-rail.js в рантайме). Слаги совпадают с планом сайта /
// SEO-кластерами; пока контента нет → showcaseItems=[] → лента скрыта (§8.4).
// Обложка/заголовок берутся из коллекции — реальные данные (CLAUDE правило 4).
const showcasePicks: ReadonlyArray<{
  kind: 'article' | 'route' | 'restaurant';
  category: string;
  slug: string;
  edaSlug?: string;
  kicker: keyof typeof dict.home.showcase.kickers;
  quality?: boolean;
  place?: boolean;
  city?: string;
  cardTitle?: string;
  mapUrl?: string;
}> = [
  { kind: 'article', category: 'cities', slug: 'things-to-do-in-sarajevo', kicker: 'city', city: 'Sarajevo' },
  { kind: 'article', category: 'cities', slug: 'things-to-do-in-mostar', kicker: 'city', city: 'Mostar' },
  { kind: 'article', category: 'cities', slug: 'trebinje-travel-guide', kicker: 'city', city: 'Trebinje' },
  { kind: 'route', category: 'routes', slug: 'bosnia-7-day-itinerary', kicker: 'route' },
  { kind: 'article', category: 'attractions', slug: 'kravice-waterfalls', kicker: 'sight' },
  { kind: 'article', category: 'attractions', slug: 'stari-most-old-bridge', kicker: 'sight' },
  { kind: 'article', category: 'attractions', slug: 'blagaj-tekke', kicker: 'sight' },
  { kind: 'article', category: 'cities', slug: 'jajce-waterfall-fortress', kicker: 'city', city: 'Jajce' },
  { kind: 'article', category: 'planning', slug: 'is-bosnia-safe', kicker: 'sight' },
  { kind: 'article', category: 'car-rental', slug: 'car-rental-bosnia', kicker: 'sight' },
  { kind: 'article', category: 'planning', slug: 'best-time-to-visit-bosnia', kicker: 'sight' },
  { kind: 'article', category: 'planning', slug: 'bosnia-trip-cost-budget', kicker: 'sight' },
];
const showcaseItems: ShowcaseItem[] = [];
for (const pick of showcasePicks) {
  if (pick.kind === 'restaurant') {
    const r = showcaseRestaurants.find((x) => x.data.slug === pick.slug);
    if (!r || !r.data.cover) continue;
    showcaseItems.push({
      href: `${sectionHref(lang, 'food')}${pick.edaSlug}/#r-${r.data.slug}`,
      title: r.data.name,
      cover: r.data.cover,
      kicker: dict.home.showcase.kickers[pick.kicker],
      city: r.data.city,
      place: true,
      quality: r.data.qualityMark === true,
      subtitle: r.data.cuisine,
      hours: r.data.hours,
      info: r.data.summary,
      address: r.data.geo.address,
      mapUrl: r.data.mapUrl,
      website: r.data.website,
      instagram: r.data.instagram,
      photos: [
        { src: r.data.cover.src, alt: r.data.cover.alt, credit: r.data.coverCredit },
        ...(r.data.gallery ?? []).map((g) => ({ src: g.src, alt: g.alt, credit: g.credit })),
      ],
    });
    continue;
  }
  const entry =
    pick.kind === 'route'
      ? visibleRoutes.find((r) => r.data.slug === pick.slug)
      : visibleArticles.find((a) => a.data.category === pick.category && a.data.slug === pick.slug);
  if (!entry || !entry.data.cover) continue;
  const category = pick.kind === 'route' ? 'routes' : pick.category;
  const p = pick as {
    quality?: boolean;
    city?: string;
    place?: boolean;
    cardTitle?: string;
    mapUrl?: string;
  };
  if (p.place) {
    // Статья-место (Teatro): рендерим как place-карточку витрины с поповером
    // (адрес/часы/карта/сайт) и каруселью фото — как у заведений.
    const defaultCity = 'Sarajevo';
    showcaseItems.push({
      href: articleHref(lang, category, entry.data.slug),
      title: p.cardTitle ?? entry.data.title,
      cover: entry.data.cover,
      kicker: dict.home.showcase.kickers[pick.kicker],
      city: p.city ?? defaultCity,
      place: true,
      quality: p.quality === true,
      hours: entry.data.visit?.hours,
      info: entry.data.description,
      address: entry.data.geo?.address,
      mapUrl: p.mapUrl,
      website: entry.data.website,
      instagram: entry.data.instagram,
      photos: [
        { src: entry.data.cover.src, alt: entry.data.cover.alt },
        ...(entry.data.gallery ?? []).map((g: { src: string; alt: string; credit?: string }) => ({
          src: g.src,
          alt: g.alt,
          credit: g.credit,
        })),
      ],
    });
    continue;
  }
  showcaseItems.push({
    href: articleHref(lang, category, entry.data.slug),
    title: entry.data.title,
    cover: entry.data.cover,
    kicker: dict.home.showcase.kickers[pick.kicker],
    // Знак качества на карточке-статье — только по запросу владельца (Teatro).
    quality: p.quality === true,
    // Опознавательный пин-чип города (для заведений). Задаётся явно у pick:
    // напр. { kind:'article', category:'food', slug:'…', kicker:'food', city:'Сараево' }.
    // У текущих контентных карточек (города/маршруты) не задан → чип не рисуется.
    city: p.city,
  });
}
// Открытое рекламное место («Разместите своё заведение») убрано с витрины по
// решению владельца 2026-06-17. Поддержка ad-слота в ShowcaseRail оставлена
// спящей — чтобы вернуть, снова добавить сюда showcaseItems.push({ ad:true, ... }).
---

<BaseLayout title={pageTitle} description={description} lang={lang}>
  {
    /* 1. Hero — текстовый, без тяжёлой картинки (LCP, §15).
       data-hero-stagger: мягкий вход H1→подзаголовок→поиск (≤450мс), только
       при .js-anim и разрешённом движении (FOUC-safe, см. global.css). */
  }
  <section class="hero" data-hero-rotate>
    {
      /* CC-кадры кросс-фейдом; градиент в CSS — фолбэк. Скрим — контраст текста.
         ПЛЕЙСХОЛДЕР до подбора реальных фото Боснии (см. heroImages выше). */
    }
    {
      heroImages.map((img, idx) => (
        <img
          class:list={['hero__bg', { 'is-active': idx === 0 }]}
          src={img.src}
          width={img.w}
          height={img.h}
          alt=""
          decoding="async"
          loading={idx === 0 ? 'eager' : 'lazy'}
          fetchpriority={idx === 0 ? 'high' : undefined}
          data-credit={heroCredit(img)}
          data-credit-href={img.href}
        />
      ))
    }
    <div class="hero__scrim"></div>
    <div class="container hero__content" data-hero-stagger>
      <h1 class="hero__title">{dict.home.heroTitle}</h1>
      <p class="hero__subtitle">{dict.home.heroSubtitle}</p>
      <SearchBox lang={lang} items={searchItems} />
    </div>
    {
      heroCredit(heroImages[0]) && (
        <a
          class="hero__credit"
          data-hero-credit
          href={heroImages[0].href}
          target="_blank"
          rel="noopener nofollow"
        >
          {heroCredit(heroImages[0])}
        </a>
      )
    }
    <script is:inline type="module" src="/js/hero-rotate.js"></script>
  </section>

  {/* Новости — последние 3 опубликованные новости; блок скрывается, если новостей нет (§8.4). */}
  {
    hasHomeNews && (
      <section class="block news-strip" data-news-section data-reveal>
        <div class="container" data-news-feed>
          <div class="news-strip__head">
            <h2 class="block__heading">{dict.newsFeed.recentHeading}</h2>
            <a class="news-strip__all" href={sectionHref(lang, 'news')}>
              {dict.newsFeed.all}
              <Icon name="arrow-right" size={16} />
            </a>
          </div>
          <ul class="news-strip__list">
            {homeNews.map((n) => (
              <li class="news-strip__item" data-news-item data-published={n.iso}>
                <time class="news-strip__date">{n.date}</time>
                <a class="news-strip__link" href={n.href}>
                  {n.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  {
    /* 2. Витрина — золотая лента партнёров/материалов (заменяет «С чего начать»).
       Лента и её заголовок показываются только при наличии featured-контента
       (showcaseItems). Пока его нет (города/маршруты/места Боснии), секция
       несёт лишь строку доверия, а не зияет пустой лентой. */
  }
  <section class="block block--showcase">
    <div class="container">
      {
        showcaseItems.length > 0 && (
          <>
            <h2 class="block__heading" data-reveal>
              {dict.home.showcase.heading}
            </h2>
            <p class="showcase-lead" data-reveal>
              {dict.home.showcase.lead}{' '}
              <span class="showcase-lead__partner">{dict.home.showcase.partnerNote}</span>
            </p>
            <ShowcaseRail lang={lang} items={showcaseItems} label={dict.home.showcase.aria} />
          </>
        )
      }
      <p class="trust-line" data-reveal>
        {dict.home.trustLead}{' '}
        <a class="trust-line__link" href={sectionHref(lang, 'about')}>
          {dict.home.about.link}
          <Icon name="arrow-right" size={16} />
        </a>
      </p>
    </div>
  </section>

  {
    /* 2b. Разделы путеводителя — on-page входы во ВСЕ разделы, включая «денежные»
       (Транспорт/Аренда/Страховки/Новости), иначе зарытые в ☰/футер (аудит NAV-2). */
  }
  <section class="block block--sections">
    <div class="container">
      <h2 class="block__heading" data-reveal>{dict.home.sectionsHeading}</h2>
      <ul class="home-sections" data-reveal>
        {
          ALL_SECTION_KEYS.map((key) => (
            <li>
              <a class="home-section" href={sectionHref(lang, key)}>
                <span>{dict.nav[key]}</span>
                <Icon name="arrow-right" size={16} />
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* 3. Услуги для жизни в Боснии и Герцеговине — заметный CTA-бэнд (продаваемый инвентарь, §16). */}
  <section class="services-band">
    <div class="container services-band__inner" data-reveal>
      <div class="services-band__text">
        <h2 class="services-band__title">{dict.relocation.uslugi.heading}</h2>
        <p class="services-band__lead">{dict.relocation.uslugi.text}</p>
      </div>
      <a class="services-band__cta" href={`${sectionHref(lang, 'relocation')}services/`}>
        {dict.relocation.uslugi.cta}
        <Icon name="arrow-right" size={18} />
      </a>
    </div>
  </section>

  {/* 4. Свежие материалы — витрина 6 последних статей (или честное пустое состояние) */}
  <section class="block">
    <div class="container">
      <h2 class="block__heading" data-reveal>{dict.home.freshHeading}</h2>
      {
        hasFresh ? (
          <div class="fresh-grid">
            {freshCards.map((card) => (
              <ArticleCard
                lang={lang}
                href={card.href}
                title={card.title}
                description={card.description}
                cover={card.cover}
                date={card.date}
                verified={card.verified}
                verifiedPhoto={card.verifiedPhoto}
                meta={[]}
              />
            ))}
          </div>
        ) : (
          <div data-reveal>
            <EmptyHint text={dict.home.freshEmpty} />
          </div>
        )
      }
    </div>
  </section>

  {/* 6. О проекте — нейтральный блок со ссылкой на /about/ */}
  <section class="block">
    <div class="container about">
      <h2 class="block__heading" data-reveal>{dict.home.about.heading}</h2>
      <p class="about__text" data-reveal>{dict.home.about.text}</p>
      <a class="about__link" href={sectionHref(lang, 'about')} data-reveal>
        {dict.home.about.link}
        <Icon name="arrow-right" size={18} />
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: var(--container-content);
    margin: 0 auto;
    padding-inline: var(--space-4);
  }

  /* Hero — кросс-фейд CC-кадров (/js/hero-rotate.js) + тёмный скрим,
     светлый текст. Первый кадр — LCP-элемент (eager+high), остальные lazy. Скрим
     обеспечивает контраст ≥4.5 (§6). Движение — opacity, параллакса нет → §15. */
  .hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    min-height: clamp(440px, 72vh, 660px);
    overflow: hidden;
    /* Тёплый бренд-градиент (вино → солнце) — фолбэк под фото hero. */
    background: linear-gradient(
      125deg,
      color-mix(in srgb, var(--color-wine) 58%, var(--color-slate)) 0%,
      var(--color-wine) 52%,
      var(--color-sun) 100%
    );
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 50%;
    /* Кросс-фейд ротации (/js/hero-rotate.js): неактивные кадры прозрачны. Первый
       приходит с .is-active из HTML → виден сразу (LCP, без fade-in на загрузке). */
    opacity: 0;
    transition: opacity 1100ms var(--ease-standard);
  }
  .hero__bg.is-active {
    opacity: 1;
  }
  /*
   * Скрим направленный: тёмный слева (под текстом) → прозрачный справа, чтобы
   * фото оставалось ярким (правка владельца 2026-06-17). Плюс лёгкая подложка
   * снизу под кредит. На мобайле текст шире → вертикальный градиент (легче, чем
   * раньше: 10/42/60 вместо 20/44/74), читаемость держит усиленная тень текста.
   */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(
        90deg,
        var(--hero-scrim-text) 0%,
        var(--hero-scrim-text-2) 34%,
        var(--hero-scrim-text-3) 60%,
        transparent 78%
      ),
      linear-gradient(0deg, var(--hero-scrim-base) 0%, transparent 30%);
  }
  @media (max-width: 768px) {
    .hero__scrim {
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-slate) 20%, transparent) 0%,
        color-mix(in srgb, var(--color-slate) 50%, transparent) 48%,
        color-mix(in srgb, var(--color-slate) 66%, transparent) 100%
      );
    }
  }
  .hero__content {
    position: relative;
    width: 100%;
    padding-block: var(--space-12);
  }
  .hero__title {
    font-size: var(--text-3xl);
    margin: 0;
    max-width: 18ch;
    color: var(--hero-text);
    text-shadow: var(--hero-text-shadow);
  }
