---
/**
 * LangSwitcher (§9, §12) — переключатель языков.
 * Сайт одноязычный (en): других языков нет, поэтому компонент НИЧЕГО не рендерит.
 * Оставлен в дереве для совместимости сигнатур Header/Footer (пропсы принимаются,
 * но не используются). Вернуть разметку переключателя, если сайт снова станет
 * многоязычным.
 */
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
  availableLangs?: Lang[];
}
// Пропсы принимаются для совместимости, но при одном языке свитчер не нужен.
const { lang: _lang, availableLangs: _availableLangs } = Astro.props;
---
